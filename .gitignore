# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using wildcard pattern
# !example_override.tf

# Include any files or directories that you do not want to be ignored
# !.terraform.lock.hcl

# Ignore .terraformrc and terraform.rc
.terraformrc
terraform.rc
